{
  "name": "nodrix-app",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "description": "Nodrix monorepo. Root package is provided so Railway can deploy from the repository root.",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev": "node --watch backend/src/server.js",
    "health": "node -e \"fetch('http://localhost:3000/health').then(r=>r.text()).then(console.log).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  }
}
